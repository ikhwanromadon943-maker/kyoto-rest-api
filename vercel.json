{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/status", "destination": "/status.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/changelog", "destination": "/changelog.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/api/ai/:path*", "destination": "/api/ai" },
    { "source": "/api/tools/:path*", "destination": "/api/tools" },
    { "source": "/api/media/:path*", "destination": "/api/media" },
    { "source": "/api/manga/:path*", "destination": "/api/manga" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ]
}