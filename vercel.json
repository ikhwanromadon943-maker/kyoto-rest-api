{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/status", "destination": "/status.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/changelog", "destination": "/changelog.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/api/ai/:path*", "destination": "/api/ai" },
    { "source": "/api/anime/:path*", "destination": "/api/anime" },
    { "source": "/api/news/:path*", "destination": "/api/news" },
    { "source": "/api/fun/:path*", "destination": "/api/fun" },
    { "source": "/api/games/:path*", "destination": "/api/games" },
    { "source": "/api/info/:path*", "destination": "/api/info" },
    { "source": "/api/maker/:path*", "destination": "/api/maker" },
    { "source": "/api/stalker/:path*", "destination": "/api/stalker" },
    { "source": "/api/random/:path*", "destination": "/api/random" },
    { "source": "/api/zodiak/:path*", "destination": "/api/zodiak" },
    { "source": "/api/tools/:path*", "destination": "/api/tools" },
    { "source": "/api/media/:path*", "destination": "/api/media" },
    { "source": "/api/crypto/:path*", "destination": "/api/crypto" },
    { "source": "/api/quran/:path*", "destination": "/api/quran" },
    { "source": "/api/animals/:path*", "destination": "/api/animals" },
    { "source": "/api/number-fact/:path*", "destination": "/api/number-fact" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ]
}