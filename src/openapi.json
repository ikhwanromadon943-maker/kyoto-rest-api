  "paths": {
    "/api/ai/chatgpt": {
      "get": {
        "tags": ["AI"],
        "summary": "ChatGPT AI",
        "description": "AI chat via Pollinations.ai. Free, no key.",
        "parameters": [
          {
            "name": "text",
            "required": true,
            "description": "Your message",
            "schema": { "type": "string", "example": "Hello, how are you?" }
          }
        ]
      }
    },
    "/api/ai/dalle": {
      "get": {
        "tags": ["AI"],
        "summary": "DALL·E Image Generator",
        "description": "Generate AI images via Pollinations.ai.",
        "parameters": [
          {
            "name": "prompt",
            "required": true,
            "description": "Image description",
            "schema": { "type": "string", "example": "A futuristic city at sunset" }
          },
          {
            "name": "size",
            "required": false,
            "description": "Image size (WxH)",
            "schema": { "type": "string", "default": "512x512" }
          }
        ]
      }
    },
    "/api/ai/translate": {
      "get": {
