{
  "openapi": "3.0.0",
  "info": {
    "title": "Kyoto API",
    "version": "2.0.0",
    "description": "Kyoto API — 55+ Live REST API Endpoints. AI, Anime, News, Fun, Games, Info, Maker, Stalker, Random, Zodiak, Tools, Media, Crypto, Quran, Animals & Number Facts. All free, no API key, no self-host."
  },
  "tags": [
    { "name": "AI", "description": "ChatGPT, DALL·E, Translate, Text-to-Speech (Pollinations.ai & Google Translate)" },
    { "name": "Anime", "description": "Manga Search, Anime Info, Random Manga, Waifu Images, Character Search (Jikan API v4 & Waifu.pics)" },
    { "name": "News", "description": "CNN Indonesia, CNBC Indonesia, Detik.com (Berita Indo API)" },
    { "name": "Fun", "description": "Jokes, Dad Jokes, Random Facts, Chuck Norris, Quotes, Cat Facts, Bored Activities" },
    { "name": "Games", "description": "Free PC Games List & Detail (FreeToGame API)" },
    { "name": "Info", "description": "Wikipedia, Dictionary, GitHub User, NPM Package, Country Info, Public Holidays" },
    { "name": "Maker", "description": "Canvas Generator, Meme Generator, Quote Image, Password Generator" },
    { "name": "Stalker", "description": "IP Lookup, My IP, DNS Lookup" },
    { "name": "Random", "description": "Random User, Random Number, UUID, Random Color, Timestamp" },
    { "name": "Zodiak", "description": "Daily Horoscope (Aztro API)" },
    { "name": "Tools", "description": "QR Code, URL Shortener, Weather, Calculator, Website Screenshot" },
    { "name": "Media", "description": "Canvas, Meme, Quote Image Generator" },
    { "name": "Crypto", "description": "Cryptocurrency Price & Top 20 List (CoinCap)" },
    { "name": "Quran", "description": "Surah Info & Keyword Search (Al-Quran.cloud)" },
    { "name": "Animals", "description": "Random Dog Image, Random Cat Image, Cat Facts" },
    { "name": "Number Facts", "description": "Random Facts, Number Facts, Math Facts, Year Facts (NumbersAPI)" }
  ],
  "paths": {
    "/api/ai/chatgpt": { "get": { "tags": ["AI"], "summary": "ChatGPT AI", "description": "AI chat via Pollinations.ai. Free, no key.", "parameters": [{ "name": "text", "required": true, "description": "Your message", "schema": { "type": "string", "example": "Hello" } }] } },
    "/api/ai/dalle": { "get": { "tags": ["AI"], "summary": "DALL·E Image", "description": "Generate AI images via Pollinations.ai.", "parameters": [{ "name": "prompt", "required": true, "description": "Image description", "schema": { "type": "string" } }, { "name": "size", "required": false, "description": "Size (WxH)", "schema": { "type": "string", "default": "512x512" } }] } },
    "/api/ai/translate": { "get": { "tags": ["AI"], "summary": "Translate Text", "description": "Google Translate. Auto-detect source.", "parameters": [{ "name": "text", "required": true, "description": "Text to translate", "schema": { "type": "string" } }, { "name": "to", "required": false, "description": "Target language code", "schema": { "type": "string", "default": "en" } }] } },
    "/api/ai/text-to-speech": { "get": { "tags": ["AI"], "summary": "Text to Speech", "description": "Convert text to speech audio URL via Pollinations.ai.", "parameters": [{ "name": "text", "required": true, "description": "Text to convert", "schema": { "type": "string" } }] } },
    "/api/ai/image-variation": { "get": { "tags": ["AI"], "summary": "Image Variation", "description": "Generate variations of an image prompt with different seeds.", "parameters": [{ "name": "prompt", "required": true, "description": "Base prompt", "schema": { "type": "string" } }] } },
    "/api/anime/search": { "get": { "tags": ["Anime"], "summary": "Manga Search", "description": "Search manga by title via Jikan API v4.", "parameters": [{ "name": "query", "required": true, "description": "Manga title", "schema": { "type": "string", "example": "One Piece" } }] } },
    "/api/anime/anime": { "get": { "tags": ["Anime"], "summary": "Anime Info", "description": "Get anime details via Jikan API v4.", "parameters": [{ "name": "title", "required": true, "description": "Anime title", "schema": { "type": "string", "example": "Jujutsu Kaisen" } }] } },
    "/api/anime/random": { "get": { "tags": ["Anime"], "summary": "Random Manga", "description": "Get a random manga from MyAnimeList.", "parameters": [] } },
    "/api/anime/waifu": { "get": { "tags": ["Anime"], "summary": "Waifu Image", "description": "Random anime images by category via Waifu.pics.", "parameters": [{ "name": "category", "required": false, "description": "Image category", "schema": { "type": "string", "default": "waifu", "enum": ["waifu", "neko", "shinobu", "megumin"] } }] } },
    "/api/anime/character": { "get": { "tags": ["Anime"], "summary": "Character Search", "description": "Search anime characters via Jikan API v4.", "parameters": [{ "name": "query", "required": true, "description": "Character name", "schema": { "type": "string", "example": "Naruto" } }] } },
    "/api/news/cnn": { "get": { "tags": ["News"], "summary": "CNN Indonesia", "description": "Latest news from CNN Indonesia.", "parameters": [] } },
    "/api/news/cnbc": { "get": { "tags": ["News"], "summary": "CNBC Indonesia", "description": "Latest news from CNBC Indonesia.", "parameters": [] } },
    "/api/news/detik": { "get": { "tags": ["News"], "summary": "Detik.com", "description": "Latest news from Detik.com.", "parameters": [] } },
    "/api/fun/joke": { "get": { "tags": ["Fun"], "summary": "Random Joke", "description": "Get a random joke via JokeAPI.", "parameters": [] } },
    "/api/fun/dadjoke": { "get": { "tags": ["Fun"], "summary": "Dad Joke", "description": "Get a random dad joke via icanhazdadjoke.", "parameters": [] } },
    "/api/fun/fact": { "get": { "tags": ["Fun"], "summary": "Random Fact", "description": "Get a useless random fact.", "parameters": [] } },
    "/api/fun/chuck-norris": { "get": { "tags": ["Fun"], "summary": "Chuck Norris Joke", "description": "Get a Chuck Norris joke.", "parameters": [] } },
    "/api/fun/quote": { "get": { "tags": ["Fun"], "summary": "Random Quote", "description": "Get an inspirational quote via Quotable.", "parameters": [] } },
    "/api/fun/cat-fact": { "get": { "tags": ["Fun"], "summary": "Cat Fact", "description": "Get a random cat fact.", "parameters": [] } },
    "/api/fun/bored": { "get": { "tags": ["Fun"], "summary": "Bored Activity", "description": "Get a random activity suggestion.", "parameters": [] } },
    "/api/games/list": { "get": { "tags": ["Games"], "summary": "Free Games List", "description": "List of free PC games via FreeToGame.", "parameters": [] } },
    "/api/games/detail": { "get": { "tags": ["Games"], "summary": "Game Detail", "description": "Detail of a specific free game.", "parameters": [{ "name": "id", "required": true, "description": "Game ID", "schema": { "type": "number" } }] } },
    "/api/info/wikipedia": { "get": { "tags": ["Info"], "summary": "Wikipedia Summary", "description": "Get Wikipedia article summary.", "parameters": [{ "name": "title", "required": true, "description": "Article title", "schema": { "type": "string", "example": "Indonesia" } }] } },
    "/api/info/dictionary": { "get": { "tags": ["Info"], "summary": "Dictionary", "description": "Look up word definitions.", "parameters": [{ "name": "word", "required": true, "description": "English word", "schema": { "type": "string", "example": "hello" } }] } },
    "/api/info/github": { "get": { "tags": ["Info"], "summary": "GitHub User", "description": "Get GitHub user info.", "parameters": [{ "name": "username", "required": true, "description": "GitHub username", "schema": { "type": "string", "example": "torvalds" } }] } },
    "/api/info/npm": { "get": { "tags": ["Info"], "summary": "NPM Package", "description": "Get NPM package info.", "parameters": [{ "name": "package", "required": true, "description": "Package name", "schema": { "type": "string", "example": "express" } }] } },
    "/api/info/country": { "get": { "tags": ["Info"], "summary": "Country Info", "description": "Get country information via REST Countries.", "parameters": [{ "name": "name", "required": true, "description": "Country name", "schema": { "type": "string", "example": "Japan" } }] } },
    "/api/info/holiday": { "get": { "tags": ["Info"], "summary": "Public Holidays", "description": "Get public holidays for a country.", "parameters": [{ "name": "year", "required": false, "description": "Year", "schema": { "type": "number", "default": 2026 } }, { "name": "country", "required": false, "description": "Country code", "schema": { "type": "string", "default": "ID" } }] } },
    "/api/maker/canvas": { "get": { "tags": ["Maker"], "summary": "Canvas Generator", "description": "Generate custom canvas image with text.", "parameters": [{ "name": "text", "required": true, "description": "Text on canvas", "schema": { "type": "string" } }] } },
    "/api/maker/meme": { "get": { "tags": ["Maker"], "summary": "Meme Generator", "description": "Generate meme image with top & bottom text.", "parameters": [{ "name": "top", "required": false, "description": "Top text", "schema": { "type": "string" } }, { "name": "bottom", "required": false, "description": "Bottom text", "schema": { "type": "string" } }] } },
    "/api/maker/quote-image": { "get": { "tags": ["Maker"], "summary": "Quote Image", "description": "Generate Quote Image.", "parameters": [{ "name": "text", "required": false, "description": "Quote", "schema": { "type": "string" } }, { "name": "author", "required": false, "description": "Author", "schema": { "type": "string" } }] } },
    "/api/maker/password": { "get": { "tags": ["Maker"], "summary": "Password Generator", "description": "Generate secure password.", "parameters": [{ "name": "length", "required": false, "description": "Length", "schema": { "type": "number", "default": 16 } }] } },
    "/api/stalker/ip": { "get": { "tags": ["Stalker"], "summary": "IP Lookup", "description": "Lookup IP address information.", "parameters": [{ "name": "ip", "required": false, "description": "IP address", "schema": { "type": "string" } }] } },
    "/api/stalker/my-ip": { "get": { "tags": ["Stalker"], "summary": "My IP", "description": "Get your current IP address info.", "parameters": [] } },
    "/api/stalker/dns": { "get": { "tags": ["Stalker"], "summary": "DNS Lookup", "description": "DNS lookup for a domain.", "parameters": [{ "name": "domain", "required": true, "description": "Domain", "schema": { "type": "string", "example": "google.com" } }] } },
    "/api/random/user": { "get": { "tags": ["Random"], "summary": "Random User", "description": "Generate random user data.", "parameters": [] } },
    "/api/random/number": { "get": { "tags": ["Random"], "summary": "Random Number", "description": "Generate random number in range.", "parameters": [{ "name": "min", "required": false, "description": "Min", "schema": { "type": "number", "default": 0 } }, { "name": "max", "required": false, "description": "Max", "schema": { "type": "number", "default": 100 } }] } },
    "/api/random/uuid": { "get": { "tags": ["Random"], "summary": "UUID Generator", "description": "Generate random UUID v4.", "parameters": [] } },
    "/api/random/color": { "get": { "tags": ["Random"], "summary": "Random Color", "description": "Generate random HEX & RGB color.", "parameters": [] } },
    "/api/random/timestamp": { "get": { "tags": ["Random"], "summary": "Timestamp", "description": "Get current Unix timestamp & ISO date.", "parameters": [] } },
    "/api/zodiak/horoscope": { "get": { "tags": ["Zodiak"], "summary": "Daily Horoscope", "description": "Get daily horoscope by zodiac sign.", "parameters": [{ "name": "sign", "required": true, "description": "Zodiac sign", "schema": { "type": "string", "example": "aries", "enum": ["aries", "taurus", "gemini", "cancer", "leo", "virgo", "libra", "scorpio", "sagittarius", "capricorn", "aquarius", "pisces"] } }, { "name": "day", "required": false, "description": "Day", "schema": { "type": "string", "default": "today", "enum": ["today", "tomorrow", "yesterday"] } }] } },
    "/api/tools/qr": { "get": { "tags": ["Tools"], "summary": "QR Code", "description": "Generate QR code via goQR.me.", "parameters": [{ "name": "text", "required": true, "description": "Text/URL", "schema": { "type": "string" } }] } },
    "/api/tools/shortlink": { "get": { "tags": ["Tools"], "summary": "URL Shortener", "description": "Shorten URLs via is.gd.", "parameters": [{ "name": "url", "required": true, "description": "Long URL", "schema": { "type": "string" } }] } },
    "/api/tools/cuaca": { "get": { "tags": ["Tools"], "summary": "Weather", "description": "Get weather by city via Open-Meteo.", "parameters": [{ "name": "city", "required": true, "description": "City name", "schema": { "type": "string", "example": "Tokyo" } }] } },
    "/api/tools/calculator": { "get": { "tags": ["Tools"], "summary": "Calculator", "description": "Evaluate math expression.", "parameters": [{ "name": "expr", "required": true, "description": "Expression", "schema": { "type": "string", "example": "2+2*3" } }] } },
    "/api/tools/ssweb": { "get": { "tags": ["Tools"], "summary": "Screenshot Website", "description": "Take screenshot of a website via Microlink.", "parameters": [{ "name": "url", "required": true, "description": "Website URL", "schema": { "type": "string", "example": "https://google.com" } }] } },
    "/api/media/canvas": { "get": { "tags": ["Media"], "summary": "Canvas Image", "description": "Generate canvas image with text.", "parameters": [{ "name": "text", "required": true, "description": "Text", "schema": { "type": "string" } }] } },
    "/api/media/meme": { "get": { "tags": ["Media"], "summary": "Meme Generator", "description": "Generate meme image.", "parameters": [{ "name": "top", "required": false, "description": "Top text", "schema": { "type": "string" } }, { "name": "bottom", "required": false, "description": "Bottom text", "schema": { "type": "string" } }] } },
    "/api/media/quote-image": { "get": { "tags": ["Media"], "summary": "Quote Image", "description": "Generate quote image.", "parameters": [{ "name": "text", "required": false, "description": "Quote", "schema": { "type": "string" } }, { "name": "author", "required": false, "description": "Author", "schema": { "type": "string" } }] } },
    "/api/crypto/price": { "get": { "tags": ["Crypto"], "summary": "Crypto Price", "description": "Get cryptocurrency price via CoinCap.", "parameters": [{ "name": "id", "required": false, "description": "Crypto ID", "schema": { "type": "string", "default": "bitcoin" } }] } },
    "/api/crypto/list": { "get": { "tags": ["Crypto"], "summary": "Crypto List", "description": "Top 20 cryptocurrencies via CoinCap.", "parameters": [] } },
    "/api/quran/surah": { "get": { "tags": ["Quran"], "summary": "Surah Info", "description": "Get surah information.", "parameters": [{ "name": "number", "required": false, "description": "Surah number", "schema": { "type": "number", "default": 1 } }] } },
    "/api/quran/search": { "get": { "tags": ["Quran"], "summary": "Search Quran", "description": "Search keywords in Quran.", "parameters": [{ "name": "keyword", "required": true, "description": "Search keyword", "schema": { "type": "string", "example": "Allah" } }] } },
    "/api/animals/dog": { "get": { "tags": ["Animals"], "summary": "Random Dog", "description": "Get random dog image via Dog CEO.", "parameters": [] } },
    "/api/animals/cat": { "get": { "tags": ["Animals"], "summary": "Random Cat", "description": "Get random cat image via Cataas.", "parameters": [] } },
    "/api/animals/cat-fact": { "get": { "tags": ["Animals"], "summary": "Cat Fact", "description": "Get a random cat fact.", "parameters": [] } },
    "/api/number-fact/random": { "get": { "tags": ["Number Facts"], "summary": "Random Fact", "description": "Get a random number fact.", "parameters": [] } },
    "/api/number-fact/number": { "get": { "tags": ["Number Facts"], "summary": "Number Fact", "description": "Get a fact about a specific number.", "parameters": [{ "name": "number", "required": false, "description": "Number", "schema": { "type": "number", "default": 42 } }] } },
    "/api/number-fact/math": { "get": { "tags": ["Number Facts"], "summary": "Math Fact", "description": "Get a mathematical fact about a number.", "parameters": [{ "name": "number", "required": false, "description": "Number", "schema": { "type": "number", "default": 42 } }] } },
    "/api/number-fact/year": { "get": { "tags": ["Number Facts"], "summary": "Year Fact", "description": "Get a historical fact about a year.", "parameters": [{ "name": "year", "required": false, "description": "Year", "schema": { "type": "number", "default": 2024 } }] } }
  }
}