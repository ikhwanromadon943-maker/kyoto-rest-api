{
  "openapi": "3.0.0",
  "info": {
    "title": "Kyoto API",
    "version": "1.0.0",
    "description": "High-performance REST API dengan 30+ endpoint. Semua endpoint kini terhubung ke API publik sungguhan.",
    "externalDocs": {
      "description": "GitHub Repository",
      "url": "https://github.com/your-username/kyoto-api"
    }
  },
  "tags": [
    { "name": "AI", "description": "ChatGPT (free-unoficial-gpt4o-mini), DALL·E (pollinations.ai), Translate (lingva.ml)" },
    { "name": "Downloader", "description": "TikTok, Instagram, YouTube, Twitter, Spotify (self-hosted scraper)" },
    { "name": "Tools", "description": "Screenshot (microlink.io), QR (goQR.me), Shortlink (is.gd), Weather (Open-Meteo)" },
    { "name": "Storage", "description": "Upload/List/Delete (production: Cloudinary/S3)" },
    { "name": "Media", "description": "Canvas/Sticker/Meme (pollinations.ai), RemoveBG (withoutbg.com)" },
    { "name": "Manga", "description": "Search/Chapter/Anime (Jikan API v4), Waifu (Waifu.pics)" }
  ],
  "paths": {
    "/api/ai/chatgpt": {
      "get": {
        "tags": ["AI"],
        "summary": "ChatGPT Conversation (Real GPT-4o-mini)",
        "description": "Chat with real GPT-4o-mini AI via free-unoficial-gpt4o-mini-api-g70n.onrender.com. No API key required.",
        "deprecated": false,
        "parameters": [
          { "name": "text", "required": true, "description": "Your message or question", "schema": { "type": "string", "example": "Hello, who are you?" } }
        ]
      },
      "post": {
        "tags": ["AI"],
        "summary": "ChatGPT with Context",
        "description": "Send conversation history for contextual responses.",
        "deprecated": false,
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messages": { "type": "array", "description": "Array of {role, content}" }
                }
              }
            }
          }
        }
      }
    }
  }
}