        "summary": "Translate Text",
        "description": "Google Translate. Auto-detect source language.",
        "parameters": [
          {
            "name": "text",
            "required": true,
            "description": "Text to translate",
            "schema": { "type": "string", "example": "Hello world" }
          },
          {
            "name": "to",
            "required": false,
            "description": "Target language code (id, en, ja, etc)",
