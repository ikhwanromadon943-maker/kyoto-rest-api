{
  "openapi": "3.0.0",
  "info": { "title": "Kyoto API", "version": "1.0.0", "description": "High-performance REST API — All LIVE endpoints, GET only. ChatGPT, DALL·E, Translate, Weather, QR, Shortlink, Calculator, Canvas, Meme, Manga Search, Anime Info & Random Manga." },
  "tags": [
    { "name": "AI", "description": "ChatGPT, DALL·E, Translate" },
    { "name": "Tools", "description": "QR Code, Shortlink, Weather, Calculator" },
    { "name": "Media", "description": "Canvas, Meme" },
    { "name": "Manga", "description": "Search, Anime Info, Random" }
  ],
  "paths": {
    "/api/ai/chatgpt": { "get": { "tags": ["AI"], "summary": "ChatGPT", "description": "AI chat via Pollinations.ai. Free, no key.", "parameters": [{ "name": "text", "required": true, "description": "Message", "schema": { "type": "string", "example": "Hello" } }] } },
    "/api/ai/dalle": { "get": { "tags": ["AI"], "summary": "DALL·E", "description": "AI image via Pollinations.ai.", "parameters": [{ "name": "prompt", "required": true, "description": "Image description", "schema": { "type": "string" } }, { "name": "size", "required": false, "description": "Image size", "schema": { "type": "string", "default": "512x512" } }] } },
    "/api/ai/translate": { "get": { "tags": ["AI"], "summary": "Translate", "description": "Google Translate. Auto-detect source.", "parameters": [{ "name": "text", "required": true, "description": "Text", "schema": { "type": "string" } }, { "name": "to", "required": false, "description": "Target language", "schema": { "type": "string", "default": "en" } }] } },
    "/api/tools/qr": { "get": { "tags": ["Tools"], "summary": "QR Code", "description": "Generate QR code via goQR.me.", "parameters": [{ "name": "text", "required": true, "description": "Text/URL", "schema": { "type": "string" } }] } },
    "/api/tools/shortlink": { "get": { "tags": ["Tools"], "summary": "URL Shortener", "description": "Shorten URL via is.gd.", "parameters": [{ "name": "url", "required": true, "description": "Long URL", "schema": { "type": "string" } }] } },
    "/api/tools/cuaca": { "get": { "tags": ["Tools"], "summary": "Weather", "description": "Real-time weather via Open-Meteo.", "parameters": [{ "name": "city", "required": true, "description": "City name", "schema": { "type": "string", "example": "Tokyo" } }] } },
    "/api/tools/calculator": { "get": { "tags": ["Tools"], "summary": "Calculator", "description": "Evaluate math expression.", "parameters": [{ "name": "expr", "required": true, "description": "Expression", "schema": { "type": "string", "example": "2+2*3" } }] } },
    "/api/media/canvas": { "get": { "tags": ["Media"], "summary": "Canvas", "description": "Generate image with text.", "parameters": [{ "name": "text", "required": true, "description": "Text", "schema": { "type": "string" } }] } },
    "/api/media/meme": { "get": { "tags": ["Media"], "summary": "Meme", "description": "Generate meme image.", "parameters": [{ "name": "top", "required": false, "description": "Top text", "schema": { "type": "string" } }, { "name": "bottom", "required": false, "description": "Bottom text", "schema": { "type": "string" } }] } },
    "/api/manga/search": { "get": { "tags": ["Manga"], "summary": "Manga Search", "description": "Search manga via Jikan API.", "parameters": [{ "name": "query", "required": true, "description": "Title", "schema": { "type": "string" } }] } },
    "/api/manga/anime": { "get": { "tags": ["Manga"], "summary": "Anime Info", "description": "Anime details via Jikan API.", "parameters": [{ "name": "title", "required": true, "description": "Anime title", "schema": { "type": "string" } }] } },
    "/api/manga/random": { "get": { "tags": ["Manga"], "summary": "Random Manga", "description": "Random manga from MyAnimeList.", "parameters": [] } }
  }
}