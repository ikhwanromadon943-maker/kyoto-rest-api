    {
      "name": "Info",
      "description": "Wikipedia, Dictionary, GitHub User/Repo, NPM Package, Country Info, Public Holidays, IP Geolocation, Exchange Rates, Crypto Prices, Movie Info, TV Shows, Lyrics, Universities, Color Info, Time & Timezone (Various free APIs)"
    },
    {
      "name": "Maker",
      "description": "Canvas Generator, Meme Generator, Quote Image, Password Generator, Avatar, Placeholder, QR Code, Gradient, Name Card, Invoice, Resume, Logo, Color Palette (Pollinations.ai, DiceBear, goQR, Colormind)"
    },
    {
      "name": "Stalker",
      "description": "IP Lookup, My IP, DNS Lookup, WHOIS, SSL Check, Domain Check, Port Check, Website Status, Instagram Info, GitHub Activity, Email Breach Check (ip-api.com, Google DNS, SSL Labs, HaveIBeenPwned)"
    },
    {
      "name": "Tools",
      "description": "QR Code, URL Shortener, Weather, Calculator, Website Screenshot, Barcode, Lorem Ipsum, Hash Generator, Base64, URL Encode, Password, Website Meta, IP Info, Unit Converter, JSON Formatter, Timezone Converter (Various APIs)"
